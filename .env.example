# Server
PORT=8080

# Database: choose either the MYSQL* set or the DATABASE_* / DB_* alternatives
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLDATABASE=sentinel_india
MYSQLUSER=sentinel
MYSQLPASSWORD=sentinel123

# Optional alternatives
# DATABASE_URL=jdbc:mysql://localhost:3306/sentinel_india?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
# DATABASE_USERNAME=sentinel
# DATABASE_PASSWORD=sentinel123
# DB_URL=jdbc:mysql://localhost:3306/sentinel_india?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
# DB_USER=sentinel
# DB_PASS=sentinel123

# External API keys
BHUVAN_TOKEN=your_bhuvan_token
OPENAQ_KEY=your_openaq_key
OPENSKY_USER=your_opensky_username
OPENSKY_PASS=your_opensky_password
N2YO_KEY=your_n2yo_key
AISSTREAM_KEY=your_aisstream_key
RAILAPI_KEY=your_railapi_key
DATAGOVIN_KEY=your_datagovin_key
OWM_KEY=your_openweathermap_key
